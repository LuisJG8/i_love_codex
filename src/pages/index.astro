---
import Timeline from "@components/Timeline.astro";
import { timeline } from "@data/codex";
import BaseLayout from "@layouts/BaseLayout.astro";

const title = "Everything that is great about Codex";
const description =
  "A fan-made timeline of OpenAI Codex milestones and wins from 2021 through May 14, 2026.";
---

<BaseLayout title={title} description={description}>
  <header class="relative z-20 border-b border-white/10 bg-codex-void/75 backdrop-blur">
    <nav class="mx-auto flex h-16 w-full max-w-6xl items-center justify-between gap-4 px-5 sm:px-6 lg:px-8" aria-label="Primary">
      <a class="flex min-w-0 items-center gap-3" href="/" aria-label="Everything that is great about Codex home">
        <img src="/assets/codex/codex-mark.svg" alt="" class="codex-mark h-8 w-8 shrink-0" width="32" height="32" />
        <span class="text-sm font-semibold text-white">Everything that is great about Codex</span>
      </a>
    </nav>
  </header>

  <main>
    <Timeline items={timeline} />
  </main>

  <footer class="border-t border-white/10 px-5 py-8 text-sm text-slate-400 sm:px-6 lg:px-8">
    <div class="mx-auto flex w-full max-w-6xl flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <p>Not affiliated with OpenAI</p>
    </div>
  </footer>
</BaseLayout>
