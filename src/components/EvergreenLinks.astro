---
import type { EvergreenLink } from "@data/codex";

type Props = {
  links: EvergreenLink[];
};

const { links } = Astro.props;
---

<section id="links" class="mx-auto w-full max-w-6xl px-5 py-12 sm:px-6 lg:px-8">
  <div class="mb-7 max-w-3xl">
    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-codex-cyan">Evergreen</p>
    <h2 class="mt-2 text-3xl font-semibold tracking-tight text-white sm:text-4xl">Primary Codex links</h2>
    <p class="mt-3 text-sm leading-6 text-slate-300">
      Official pages to keep this archive grounded as Codex keeps moving.
    </p>
  </div>

  <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
    {links.map((link) => (
      <a
        class="surface group rounded-lg p-4 transition hover:border-codex-cyan/70 hover:bg-white/[0.07]"
        href={link.url}
        rel="noopener noreferrer"
        target="_blank"
      >
        <span class="flex items-center justify-between gap-3">
          <span class="text-base font-semibold text-white">{link.label}</span>
          <span class="text-codex-cyan transition group-hover:translate-x-0.5" aria-hidden="true">↗</span>
        </span>
        <span class="mt-2 block text-sm leading-6 text-slate-300">{link.description}</span>
      </a>
    ))}
  </div>
</section>
