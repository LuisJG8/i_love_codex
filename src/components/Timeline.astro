---
import type { TimelineItem } from "@data/codex";

type Props = {
  items: TimelineItem[];
};

type TimelineVisual = {
  label: string;
  src: string;
};

const { items } = Astro.props;
const sortedItems = [...items].sort((a, b) => b.date.localeCompare(a.date));
const dateFormatter = new Intl.DateTimeFormat("en-US", {
  month: "short",
  day: "numeric",
  year: "numeric",
  timeZone: "UTC"
});

const timelineVisuals: Record<string, TimelineVisual> = {
  "2021-08-10:OpenAI Codex enters API private beta": {
    label: "API key card, code document, and launch spark illustration",
    src: "/assets/timeline/api-private-beta.webp"
  },
  "2023-03-01:Original Codex models are deprecated": {
    label: "Archive box, retired chip, and migration arrow illustration",
    src: "/assets/timeline/original-models-deprecated.webp"
  },
  "2025-04-16:Codex CLI launches as an open-source local agent": {
    label: "Terminal, repository branch, and open-source crate illustration",
    src: "/assets/timeline/cli-open-source-agent.webp"
  },
  "2025-05-16:Cloud Codex research preview arrives in ChatGPT": {
    label: "Cloud server, parallel tasks, and repository cubes illustration",
    src: "/assets/timeline/cloud-research-preview.webp"
  },
  "2025-05-16:Early testers show real production workflows": {
    label: "Checklist, toolkit, and app tiles illustration",
    src: "/assets/timeline/early-testers-workflows.webp"
  },
  "2025-05-19:Codex reaches the ChatGPT iOS app": {
    label: "Phone, diff review, and pull request arrow illustration",
    src: "/assets/timeline/ios-app.webp"
  },
  "2025-05-22:Environment setup and latency get sharper": {
    label: "Speed gauge, container cube, and reconnecting cable illustration",
    src: "/assets/timeline/environment-latency.webp"
  },
  "2025-06-03:Codex expands to ChatGPT Plus and gains internet access controls": {
    label: "Globe, permission toggle, and shield illustration",
    src: "/assets/timeline/plus-internet-controls.webp"
  },
  "2025-06-13:Best of N makes parallel exploration a product pattern": {
    label: "Two answer cards and comparison scale illustration",
    src: "/assets/timeline/best-of-n.webp"
  },
  "2025-08-21:Image inputs, container caching, and automatic setup land": {
    label: "Image prompt card, container cube, and cache stack illustration",
    src: "/assets/timeline/image-inputs-container-caching.webp"
  },
  "2025-08-27:IDE extension, ChatGPT sign-in, handoff, and Code Reviews arrive": {
    label: "Code editor, review badge, and sign-in key illustration",
    src: "/assets/timeline/ide-extension-code-review.webp"
  },
  "2025-09-15:GPT-5-Codex launches for agentic coding": {
    label: "Model chip, code token, and rocket illustration",
    src: "/assets/timeline/gpt-5-codex-launch.webp"
  },
  "2025-09-23:GPT-5-Codex becomes available in the Responses API": {
    label: "API socket, model chip, and globe ring illustration",
    src: "/assets/timeline/responses-api.webp"
  },
  "2025-10-06:Codex reaches general availability": {
    label: "Launch rocket, release ticket, and admin sliders illustration",
    src: "/assets/timeline/general-availability.webp"
  },
  "2025-10-22:Developers can tag @Codex on GitHub issues and PRs": {
    label: "Issue ticket, mention bubble, and pull request branch illustration",
    src: "/assets/timeline/github-mentions.webp"
  },
  "2025-11-07:GPT-5-Codex-Mini adds longer-running usage": {
    label: "Small model chip, extended battery, and gauge illustration",
    src: "/assets/timeline/codex-mini-longer-usage.webp"
  },
  "2025-11-13:GPT-5.1-Codex and Mini join the picker": {
    label: "Model picker dial, two chips, and terminal sliders illustration",
    src: "/assets/timeline/gpt-5-1-picker.webp"
  },
  "2025-11-18:GPT-5.1-Codex-Max and xhigh reasoning arrive": {
    label: "Large chip, reasoning blocks, and reasoning gauge illustration",
    src: "/assets/timeline/codex-max-xhigh.webp"
  },
  "2025-12-04:Codex for Linear turns issues into cloud tasks": {
    label: "Issue ticket, progress link, and cloud task bubble illustration",
    src: "/assets/timeline/linear-cloud-tasks.webp"
  },
  "2025-12-18:GPT-5.2-Codex becomes the default for ChatGPT sign-in": {
    label: "Default toggle, upgraded chip, and terminal key illustration",
    src: "/assets/timeline/gpt-5-2-default.webp"
  },
  "2025-12-19:Agent skills give Codex reusable workflows": {
    label: "Recipe cards, toolkit, and puzzle-piece badge illustration",
    src: "/assets/timeline/agent-skills.webp"
  },
  "2026-01-14:GPT-5.2-Codex reaches API-key workflows": {
    label: "API key card, terminal, and connected model chip illustration",
    src: "/assets/timeline/api-key-workflows.webp"
  },
  "2026-01-23:Team Config standardizes Codex across repositories": {
    label: "Config file, shared repository folder, and gear illustration",
    src: "/assets/timeline/team-config.webp"
  },
  "2026-01-28:Web search is enabled by default for local tasks": {
    label: "Magnifying glass, globe, and browser card illustration",
    src: "/assets/timeline/web-search-default.webp"
  },
  "2026-02-02:The Codex app launches on macOS": {
    label: "Desktop command center, agent cards, and worktree branch illustration",
    src: "/assets/timeline/macos-app.webp"
  },
  "2026-02-05:Codex app adds GPT-5.3-Codex support and steering": {
    label: "Steering wheel, model chip, and attachment card illustration",
    src: "/assets/timeline/steering-attachments.webp"
  },
  "2026-03-25:Plugins package skills, apps, and MCP servers": {
    label: "Puzzle piece, skill card, and connector node illustration",
    src: "/assets/timeline/plugins-package.webp"
  },
  "2026-04-16:Codex expands toward almost everything": {
    label: "Command window, plugin puzzle, and task checklist illustration",
    src: "/assets/timeline/almost-everything.webp"
  },
  "2026-04-23:GPT-5.5 and Codex app updates close this archive": {
    label: "Archive box, model chip, and upgrade arrow illustration",
    src: "/assets/timeline/gpt-5-5-archive.webp"
  }
};

function formatDate(date: string) {
  const [year, month, day] = date.split("-").map(Number);
  return dateFormatter.format(new Date(Date.UTC(year, month - 1, day)));
}

function getTimelineVisual(item: TimelineItem): TimelineVisual | undefined {
  return timelineVisuals[`${item.date}:${item.title}`];
}
---

<section id="timeline" class="mx-auto w-full max-w-6xl px-5 py-14 sm:px-6 lg:px-8">
  <div class="mb-7 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-codex-cyan">Archive</p>
      <h2 class="mt-2 text-3xl font-semibold tracking-tight text-white sm:text-4xl">Milestones and wins</h2>
      <p class="mt-3 max-w-2xl text-sm leading-6 text-slate-300">
        A newest-first timeline of Codex launches, integrations, model upgrades, and workflow improvements through April 23, 2026.
      </p>
    </div>

    <button
      type="button"
      class="inline-flex h-10 w-fit items-center gap-2 rounded-md border border-codex-line bg-white/[0.06] px-3 text-sm font-medium text-white transition hover:border-codex-cyan/70 hover:bg-white/[0.1]"
      data-sort-toggle
      aria-pressed="false"
    >
      <span class="text-codex-cyan" aria-hidden="true">⇅</span>
      <span data-sort-label>Newest first</span>
    </button>
  </div>

  <ol id="timeline-list" class="timeline-list" data-order="desc">
    {sortedItems.map((item) => {
      const visual = getTimelineVisual(item);

      return (
        <li class="timeline-item" data-date={item.date}>
          <div class="timeline-axis" aria-hidden="true">
            <span class="timeline-dot"></span>
          </div>

          <article class="timeline-card surface rounded-lg p-4 sm:p-5">
            <div class="mb-4 flex flex-wrap items-center gap-2">
              <span class="timeline-count" aria-hidden="true"></span>
              <time class="text-sm font-semibold text-codex-cyan" datetime={item.date}>
                {formatDate(item.date)}
              </time>
              <span class="rounded bg-white/[0.07] px-2 py-1 text-[0.68rem] font-semibold uppercase tracking-[0.14em] text-slate-300">
                {item.category}
              </span>
            </div>

            <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
              <h3 class="text-lg font-semibold leading-snug text-white sm:text-xl">{item.title}</h3>
              {item.storyTag && (
                <span class="w-fit shrink-0 rounded border border-codex-line bg-codex-cyan/10 px-2 py-1 text-xs font-medium text-codex-cyan">
                  {item.storyTag}
                </span>
              )}
            </div>

            <p class="mt-3 text-sm font-medium leading-6 text-slate-200">{item.summary}</p>
            {item.details && (
              <p class="mt-3 text-sm leading-6 text-slate-300">{item.details}</p>
            )}

            <div class="mt-4 flex flex-wrap items-center gap-2">
              {item.metric && (
                <span class="rounded border border-codex-line bg-codex-blue/10 px-2 py-1 text-xs font-semibold text-white">
                  {item.metric}
                </span>
              )}
              {item.sources.map((source) => (
                <a
                  class="rounded border border-codex-line bg-white/[0.04] px-2 py-1 text-xs font-medium text-slate-200 transition hover:border-codex-cyan/80 hover:text-white"
                  href={source.url}
                  rel="noopener noreferrer"
                  target="_blank"
                >
                  {source.label}
                </a>
              ))}
            </div>
          </article>

          {visual && (
            <figure class="timeline-visual">
              <img
                class="timeline-visual-image"
                src={visual.src}
                alt={visual.label}
                loading="lazy"
                decoding="async"
              />
            </figure>
          )}
        </li>
      );
    })}
  </ol>

  <div class="mt-8 flex justify-center">
    <a
      class="inline-flex h-10 w-fit items-center gap-2 rounded-md border border-codex-line bg-white/[0.06] px-3 text-sm font-medium text-white transition hover:border-codex-cyan/70 hover:bg-white/[0.1]"
      href="#timeline"
    >
      <span class="text-codex-cyan" aria-hidden="true">↑</span>
      Beginning of timeline
    </a>
  </div>
</section>

<script>
  const list = document.querySelector<HTMLOListElement>("#timeline-list");
  const toggle = document.querySelector<HTMLButtonElement>("[data-sort-toggle]");
  const label = document.querySelector<HTMLElement>("[data-sort-label]");

  toggle?.addEventListener("click", () => {
    if (!list || !label) {
      return;
    }

    const nextOrder = list.dataset.order === "desc" ? "asc" : "desc";
    const entries = Array.from(list.querySelectorAll<HTMLElement>("[data-date]"));

    entries
      .sort((a, b) => {
        const left = a.dataset.date ?? "";
        const right = b.dataset.date ?? "";
        return nextOrder === "asc" ? left.localeCompare(right) : right.localeCompare(left);
      })
      .forEach((entry) => list.appendChild(entry));

    list.dataset.order = nextOrder;
    toggle.setAttribute("aria-pressed", String(nextOrder === "asc"));
    label.textContent = nextOrder === "asc" ? "Oldest first" : "Newest first";
  });
</script>
